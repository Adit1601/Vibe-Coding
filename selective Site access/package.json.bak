{
  "name": "selective-site-access",
  "version": "1.0.0",
  "description": "A Chrome extension for selective domain blocking with allowlist functionality",
  "main": "manifest.json",
  "scripts": {
    "lint": "eslint *.js",
    "lint:fix": "eslint *.js --fix",
    "build": "echo 'No build step required for Chrome extensions'",
    "test": "echo 'No tests specified'",
    "pack": "echo 'Use Chrome Web Store or manual packing'"
  },
  "keywords": [
    "chrome-extension",
    "productivity",
    "focus",
    "blocking",
    "allowlist",
    "manifest-v3"
  ],
  "author": "Your Name",
  "license": "MIT",
  "devDependencies": {
    "eslint": "^8.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/selective-site-access.git"
  },
  "bugs": {
    "url": "https://github.com/yourusername/selective-site-access/issues"
  },
  "homepage": "https://github.com/yourusername/selective-site-access#readme",
  "engines": {
    "node": ">=14.0.0"
  }
} 